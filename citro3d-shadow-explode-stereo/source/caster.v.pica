; Vertex shader — passthrough into the caster geometry shader (model-space position).
; (Identical to ico.v.pica; the caster GS re-projects into light space and only
; needs the position, but we pass the colour through too for a uniform layout.)
.constf myconst(0.0, 1.0, -1.0, -0.5)
.alias  ones myconst.yyyy

.out outpos position
.out outclr color

.alias inpos v0
.alias inclr v1

.entry vmain
.proc vmain
	mov outpos.xyz, inpos
	mov outpos.w,   ones
	mov outclr,     inclr
	end
.end
